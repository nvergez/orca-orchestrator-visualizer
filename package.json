{
  "name": "orca-viz",
  "version": "0.7.0",
  "description": "Unofficial, third-party, read-only web visualizer for Orca's orchestration database",
  "license": "MIT",
  "author": "Nicolas Vergez",
  "type": "module",
  "keywords": [
    "orca",
    "orchestration",
    "visualizer",
    "agents",
    "sqlite",
    "cli"
  ],
  "homepage": "https://github.com/nvergez/orca-viz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvergez/orca-viz.git"
  },
  "bugs": {
    "url": "https://github.com/nvergez/orca-viz/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.5"
  },
  "bin": {
    "orca-viz": "bin/orca-viz.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch src/server/main.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/server/main.js",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
