{
  // Node side: the server, the fixture builder, the node-environment tests and the
  // build/test config files. No DOM lib, so server code cannot reach for `document`.
  // The browser side is typechecked separately by tsconfig.client.json.
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    // Source imports carry the real `.ts` extension so `node src/server/main.ts` runs
    // them directly (native type stripping); tsc rewrites them to `.js` on emit.
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    "noEmit": true
  },
  "include": [
    "src/server",
    "src/shared",
    "test/fixtures",
    "test/server",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ]
}
